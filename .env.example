# =============================================
#  Smart Campus — Environment Variables
#  Copy this file to .env and fill in the values
# =============================================

# ── PostgreSQL ────────────────────────────────
DB_NAME=smartcampus
DB_USER=smartcampus
DB_PASSWORD=changeme_in_production
DB_PORT=5432

# ── pgAdmin ───────────────────────────────────
PGADMIN_EMAIL=admin@smartcampus.local
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# ── Backend ───────────────────────────────────
BACKEND_PORT=8080

# ── Google OAuth2 (required) ──────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── JWT (optional — leave blank to auto-generate in dev) ──────────────────
# In production, generate an RSA key pair and supply the Base64-encoded PEM:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
#   export JWT_PRIVATE_KEY=$(base64 -w 0 private.pem)
#   export JWT_PUBLIC_KEY=$(base64 -w 0 public.pem)
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_ACCESS_EXPIRY=900
JWT_REFRESH_EXPIRY=604800

# ── CORS ─────────────────────────────────────
CORS_ORIGINS=http://localhost:5173
FRONTEND_URL=http://localhost:5173
OAUTH2_SUCCESS_REDIRECT=http://localhost:5173/oauth/callback

# ── Profile ───────────────────────────────────
SPRING_PROFILES_ACTIVE=default
