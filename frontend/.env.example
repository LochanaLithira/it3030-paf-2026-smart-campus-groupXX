# Google OAuth credentials
# Get these from https://console.cloud.google.com → Credentials → OAuth 2.0 Client IDs
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Must match the "Authorized redirect URI" configured in Google Cloud Console
VITE_OAUTH_REDIRECT_URI=http://localhost:5173/oauth/callback

# Backend base URL (used when not running via Vite dev-server proxy)
VITE_API_BASE_URL=http://localhost:8080
